{
  "name": "custom-ts-snip",
  "displayName": "rick_snip_ts",
  "description": "My own JS snippets",
  "version": "0.0.1",
  "browser": "./lib/index.js",
  "keywords": [
    "snippets",
    "customizable",
    "javascript",
    "typescript"
  ],
  "license": "MIT",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptReact",
    "onLanguage:javascriptReact",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "typescriptSnippets.search",
        "title": "Snippet search"
      }
    ],
    "snippets": [
      {
        "language": "javascriptreact",
        "path": "./generated.json"
      },
      {
        "language": "typescript",
        "path": "./generated.json"
      },
      {
        "language": "typescriptreact",
        "path": "./generated.json"
      }
    ]
  }
}

